# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Argentum AI
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:argentum@localhost:5432/argentum_db
SYNC_DATABASE_URL=postgresql://postgres:argentum@localhost:5432/argentum_db

# ─── Redis (Celery broker + cache) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_QUIZ_MODEL=gpt-4o-mini
OPENAI_ADVANCED_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Firebase Auth ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# ─── AWS S3 (file storage) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=argentum-uploads

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_store

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
UPLOAD_SIZE_LIMIT_MB=25

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8000,http://127.0.0.1:5000
